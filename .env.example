# Dropea API
DROPEA_API_KEY=
DROPEA_API_URL=https://api.dropea.com/graphql
DROPEA_WEBHOOK_SECRET=
DROPEA_SHOP_ID=

# Dropi PRO API (fulfillment/logística — fase beta, sin catálogo de productos)
# La URL base varía por país (ej: España = https://dropipro.com)
DROPI_API_URL=
DROPI_AUTH_EMAIL=
DROPI_AUTH_TOKEN=
DROPI_STORE_ID=
# Secreto compartido para el webhook (no hay firma HMAC documentada por Dropi)
DROPI_WEBHOOK_SECRET=

# SumUp Payments
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=


# Webhook Store (memory | kv)
WEBHOOK_STORE=memory

# Site config (personalizar por nicho)
NEXT_PUBLIC_SITE_NAME=Mi Tienda
NEXT_PUBLIC_SITE_URL=https://mi-tienda.vercel.app
NEXT_PUBLIC_LOCALE=es

# Shipping (Dropea Servicio 24)
# 0 = calcular por peso (recomendado)
# numero = tarifa plana en euros (ej: 3.68)
NEXT_PUBLIC_SHIPPING_COST=0
# Monto minimo para envio gratis (0 = siempre cobrar)
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=0
